{
  "name": "@postman-sync/cli",
  "type": "module",
  "version": "0.0.0",
  "description": "CLI for postman-sync — sync OpenAPI specs into Postman collections without losing manual edits.",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "postman-sync": "./bin/postman-sync.js"
  },
  "files": ["bin", "dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@postman-sync/core": "workspace:*",
    "openapi-to-postmanv2": "6.0.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
